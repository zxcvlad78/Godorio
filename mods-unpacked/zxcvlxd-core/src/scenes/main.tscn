[sub_resource type="GDScript" id="GDScript_inmql"]
resource_name = "script"
script/source = "extends Control

@onready var ip_port: LineEdit = $Content/ScrollContainer/VBoxContainer/IP_Port
@onready var nick_name: LineEdit = $Content/ScrollContainer/VBoxContainer/NickName
@onready var button: Button = $Content/ScrollContainer/VBoxContainer/StartServer

func _ready() -> void:
	button.pressed.connect(_on_button_pressed)

func _on_button_pressed() -> void:
	var parsed = ip_port.text.split(\":\")
	if parsed.size() < 1:
		return
	
	#var ip:String = parsed.get(0)
	var port:int = int(parsed.get(1))
	
	SimusNetConnectionENet.create_server(port)
"

