[sub_resource type="GDScript" id="GDScript_jd5ws"]
resource_name = "main"
script/source = "extends Control

@onready var bg_texture: TextureRect = $BGTexture
@onready var game_name: Label = $GameName
@onready var version: Label = $Version

@onready var popups: Control = $Popups

func _ready() -> void:
	version.text = \"version %s\" % ProjectSettings.get_setting(\"application/config/version\")
	
	for btn in _get_buttons():
		btn.pressed.connect(_on_btn_pressed.bind(btn.name))

func _on_btn_pressed(btn_name:StringName) -> void:
	match btn_name:
		\"StartGame\":
			switch_popup_by_name(\"StartServer\")

func switch_popup_by_name(popup_name:StringName) -> Control:
	for c in popups.get_children():
		if c is Control:
			if c.name == popup_name:
				return switch_popup(c)
		
	return null

func switch_popup(popup:Control) -> Control:
	for c in popups.get_children():
		if c is Control:
			if c == popup:
				continue
			c.hide()
	
	popup.show()
	
	return popup

func _get_buttons(node:Node = self) -> Array[Button]:
	var result:Array[Button] = []
	for c in node.get_children():
		if c is Button:
			result.append(c)
		
		for btn in _get_buttons(c):
			result.append(btn)
	
	return result
"

