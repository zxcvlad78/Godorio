[sub_resource type="GDScript" id="GDScript_f06hy"]
resource_name = "script"
script/source = "extends Area3D

@export var audio_player:AudioStreamPlayer3D
@export var label3d:Label3D
@export var count:int = 0

func _ready() -> void:
	SimusNetRPC.register(
		[
			_receive,
			success,
			
		],
		
	)
	
	if multiplayer.is_server():
		multiplayer.peer_connected.connect(_on_peer_connected)
		body_entered.connect(_on_body_entered)

func _on_peer_connected(id:int) -> void:
	_send(id)

func _send(peer:int = -1) -> void:
	if peer == -1:
		SimusNetRPC.invoke_all(_receive, count)
		return
	SimusNetRPC.invoke_on(peer, _receive, count)

func _receive(s_count:int) -> void:
	count = s_count
	label3d.text = str(s_count)

func _on_body_entered(body: Node3D):
	if body.linear_velocity.y < 0:
		count += 1
		success(count)
		SimusNetRPC.invoke(success, count)

func success(s_count:int) -> void:
	if audio_player:
		audio_player.play()
	if label3d:
		label3d.text = str(s_count)
"

