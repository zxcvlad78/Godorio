[gd_resource type="ShaderMaterial" format=3 uid="uid://c5mtek2re4ahy"]

[sub_resource type="Shader" id="Shader_gpysl"]
code = "shader_type canvas_item;
render_mode blend_mix;

void fragment() {
	COLOR = texture(TEXTURE, vec2(UV.x, UV.y - ((1.0 - UV.y) * (clamp(sin(TIME), 0.0, 1.0) * 0.25))));
}
"

[resource]
shader = SubResource("Shader_gpysl")
